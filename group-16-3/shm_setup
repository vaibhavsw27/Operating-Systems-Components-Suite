#include <stdio.h>
#include <stdlib.h>
#include <sys/mman.h>
#include <sys/stat.h>        
#include <fcntl.h>           
#include <unistd.h>
#include <string.h>
#include "scheduler_shm.h"
#define SHM_NAME "/simplescheduler_shm"
#define SHM_SIZE sizeof(scheduler_shm_t)

scheduler_shm_t* setup_shared_memory()
 {
    int shm_fd = shm_open(SHM_NAME, O_CREAT | O_RDWR, 0666);
    if (shm_fd == -1) {
        perror("shm_open failed");
        return NULL;
    }
    if (ftruncate(shm_fd, SHM_SIZE) == -1)
     {
        perror("ftruncate failed");
        return NULL;
    }
    void *ptr = mmap(NULL, SHM_SIZE, PROT_READ | PROT_WRITE, MAP_SHARED, shm_fd, 0);
    if (ptr == MAP_FAILED) {
        perror("mmap failed");
        return NULL;
    }
    return (scheduler_shm_t *)ptr;
}

void cleanup_shared_memory(scheduler_shm_t *shm) 
{
    munmap(shm, SHM_SIZE);
    shm_unlink(SHM_NAME);
}